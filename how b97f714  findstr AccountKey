<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Melvin Francy - Resume</title>
    <meta name="description"
        content="Resume of Melvin Francy, an IMCA Postgraduate based in Kochi, India. Skilled in Python, Django, Linux, and web development.">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@300;400;500;700&family=Space+Grotesk:wght@300;400;500&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --bg-color: #08080a;
            --text-color: #d1d5db;
            --text-title: #ffffff;
            --text-muted: #71717a;
            --accent-chrome: linear-gradient(180deg, #ffffff 0%, #a1a1aa 40%, #ffffff 60%, #52525b 100%);
            --accent-silver: #c8c8cb;
            --border-thin: 1px solid rgba(255, 255, 255, 0.12);
            --card-bg: rgba(13, 13, 16, 0.85);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Space Grotesk', sans-serif;
            line-height: 1.5;
            overflow-x: hidden;
            /* Classy dot grid background on webpage */
            background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        /* Dotted grid layer inside the resume card */
        .resume-grid-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background-image: radial-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        /* Glowing reflective wave swept from bottom-right to top-left inside card */
        .resume-glow-wave {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
            background: linear-gradient(135deg, transparent 40%, rgba(255, 255, 255, 0.01) 48%, rgba(255, 255, 255, 0.07) 50%, rgba(255, 255, 255, 0.01) 52%, transparent 60%);
            background-size: 300% 300%;
            animation: waveSweep 14s ease-in-out infinite;
            mix-blend-mode: overlay;
        }

        @keyframes waveSweep {
            0% {
                background-position: 150% 150%;
            }

            50% {
                background-position: 0% 0%;
            }

            100% {
                background-position: -150% -150%;
            }
        }

        /* Abstract Art Overlay (Cybercore / Retro Futurism / Metal Heart inspiration) */
        .cybercore-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: -1;
            opacity: 0.06;
            /* Faint & faded */
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Tech corner marks */
        .corner-mark {
            position: absolute;
            width: 10px;
            height: 10px;
            color: rgba(255, 255, 255, 0.25);
            font-family: 'JetBrains Mono', monospace;
            font-size: 8px;
            pointer-events: none;
        }

        .top-left {
            top: 10px;
            left: 10px;
            border-left: 1px solid currentColor;
            border-top: 1px solid currentColor;
        }

        .top-right {
            top: 10px;
            right: 10px;
            border-right: 1px solid currentColor;
            border-top: 1px solid currentColor;
        }

        .bottom-left {
            bottom: 10px;
            left: 10px;
            border-left: 1px solid currentColor;
            border-bottom: 1px solid currentColor;
        }

        .bottom-right {
            bottom: 10px;
            right: 10px;
            border-right: 1px solid currentColor;
            border-bottom: 1px solid currentColor;
        }

        .resume-container {
            max-width: 850px;
            margin: 40px auto;
            padding: 40px;
            position: relative;
            background: var(--card-bg);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(12px);
            overflow: hidden;
        }

        /* Keep content elements on top of the background grid and glow wave */
        header,
        section,
        footer {
            position: relative;
            z-index: 10;
        }

        /* HEADER */
        header {
            position: relative;
            padding-bottom: 30px;
            margin-bottom: 35px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        }

        .header-main {
            width: 100%;
        }

        h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.8rem, 6vw, 4rem);
            font-weight: 300;
            letter-spacing: -1px;
            line-height: 1.0;
            color: var(--text-title);
            margin-bottom: 16px;
        }

        .contact-info {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
            margin-bottom: 16px;
            display: flex;
            flex-wrap: wrap;
            gap: 8px 16px;
        }

        .contact-info span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .contact-links {
            display: flex;
            gap: 16px;
            list-style: none;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
        }

        .contact-links a {
            color: var(--text-color);
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            padding-bottom: 2px;
            transition: all 0.2s ease;
        }

        .contact-links a:hover {
            color: #ffffff;
            border-bottom-color: #ffffff;
            text-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
        }

        /* SECTION TITLES & SEPARATORS */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 35px;
            margin-bottom: 20px;
        }

        .section-title-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-num {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--text-muted);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 2px 6px;
            border-radius: 2px;
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 400;
            font-style: italic;
            color: var(--text-title);
        }

        .section-line {
            flex-grow: 1;
            margin-left: 20px;
            height: 1px;
            background: linear-gradient(90deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.02) 100%);
            position: relative;
        }

        .section-line::after {
            content: '';
            position: absolute;
            left: 0;
            top: -2px;
            width: 5px;
            height: 5px;
            background-color: var(--accent-silver);
            border-radius: 50%;
        }

